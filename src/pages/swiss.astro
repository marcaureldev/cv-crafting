---
import "../styles/global.css";
import PrintBar from "../components/PrintBar.astro";
import { cv } from "../content";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{cv.identity.name} — Swiss</title>
    <style>
      :root {
        --ink: #111111;
        --paper: #f7f7f5;
        --accent: #e11d48;
        --rule: #d4d4d4;
      }
      body {
        font-family: var(--font-sans);
        background: var(--paper);
        color: var(--ink);
        font-feature-settings: "ss01", "cv11";
      }
      .num {
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum";
      }
      .rule {
        border-top: 1px solid var(--rule);
      }
      .rule-b {
        border-bottom: 1px solid var(--rule);
      }
      .accent {
        color: var(--accent);
      }
      .label {
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #525252;
      }
      .grid12 {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 24px;
      }
      @media print {
        body {
          background: white;
        }
      }
    </style>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-6xl px-8 py-12">
      <!-- Header rail -->
      <header class="grid12 rule-b pb-6">
        <div class="col-span-3">
          <p class="label">Curriculum Vitæ</p>
          <p class="label num mt-1">N° 01 / 2026</p>
        </div>
        <div class="col-span-6">
          <h1 class="text-4xl font-semibold tracking-tight">{cv.identity.name}</h1>
          <p class="mt-1 text-neutral-600">{cv.identity.title}</p>
        </div>
        <div class="col-span-3 text-right">
          <p class="label">Localisation</p>
          <p class="mt-1 text-sm">{cv.identity.location}</p>
          <p class="text-sm text-neutral-500">{cv.identity.availability}</p>
        </div>
      </header>

      <!-- Hero statement -->
      <section class="grid12 py-12 rule-b">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> Profil
          </p>
        </div>
        <div class="col-span-9">
          <p class="text-3xl font-light leading-tight tracking-tight">
            {cv.identity.tagline}
          </p>
          <div class="mt-6 max-w-3xl space-y-3 text-neutral-700 leading-relaxed">
            {cv.about.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="grid12 py-8 rule-b">
        <div class="col-span-3">
          <p class="label">Chiffres</p>
        </div>
        <div class="col-span-9 grid grid-cols-4 gap-6">
          {cv.stats.map((s) => (
            <div>
              <p class="text-4xl font-light num">{s.value}</p>
              <p class="label mt-2">{s.label}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Experience -->
      <section class="grid12 py-12 rule-b">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> 01 — Expérience
          </p>
        </div>
        <div class="col-span-9 space-y-10">
          {cv.experience.map((j) => (
            <article class="grid grid-cols-9 gap-6 pb-8 border-b border-neutral-200 last:border-0">
              <div class="col-span-3">
                <p class="label num">{j.period}</p>
                <p class="text-sm text-neutral-500 mt-1">{j.location}</p>
              </div>
              <div class="col-span-6">
                <h3 class="text-lg font-semibold">{j.role}</h3>
                <p class="text-neutral-600 text-sm">{j.company}</p>
                <p class="mt-3 text-neutral-800 leading-relaxed">{j.summary}</p>
                <ul class="mt-3 space-y-1 text-sm text-neutral-700">
                  {j.highlights.map((h) => (
                    <li class="flex gap-3">
                      <span class="accent">→</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section class="grid12 py-12 rule-b">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> 02 — Projets
          </p>
        </div>
        <div class="col-span-9 grid sm:grid-cols-3 gap-6">
          {cv.projects.map((p, i) => (
            <div>
              <p class="label num">0{i + 1}</p>
              <h3 class="mt-2 font-semibold">{p.name}</h3>
              <p class="text-sm text-neutral-600 mt-1">{p.tagline}</p>
              <p class="label mt-3">{p.stack.join(" · ")}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section class="grid12 py-12 rule-b">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> 03 — Compétences
          </p>
        </div>
        <div class="col-span-9 space-y-4">
          {[
            ["Langages", cv.skills.languages],
            ["Infrastructure", cv.skills.infra],
            ["Sécurité", cv.skills.security],
          ].map(([label, items]) => (
            <div class="grid grid-cols-9 gap-6">
              <p class="label col-span-3 pt-1">{label}</p>
              <p class="col-span-6 text-neutral-800">{(items as string[]).join(" · ")}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Education + Writing -->
      <section class="grid12 py-12 rule-b">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> 04 — Formation & Publications
          </p>
        </div>
        <div class="col-span-9 grid sm:grid-cols-2 gap-12">
          <div>
            <p class="label mb-3">Formation</p>
            <ul class="space-y-3">
              {cv.education.map((e) => (
                <li class="flex gap-4">
                  <span class="label num pt-1 w-12 shrink-0">{e.year}</span>
                  <div>
                    <p class="font-medium">{e.title}</p>
                    <p class="text-sm text-neutral-600">{e.school}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <p class="label mb-3">Publications & Talks</p>
            <ul class="space-y-3">
              {cv.writing.map((w) => (
                <li class="flex gap-4">
                  <span class="label num pt-1 w-12 shrink-0">{w.date}</span>
                  <div>
                    <p class="font-medium">{w.title}</p>
                    <p class="text-sm text-neutral-600">{w.where}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Contact / Colophon -->
      <footer class="grid12 py-10">
        <div class="col-span-3">
          <p class="label">
            <span class="accent">■</span> Contact
          </p>
        </div>
        <div class="col-span-9 grid sm:grid-cols-4 gap-4 text-sm">
          <div>
            <p class="label">Email</p>
            <p class="mt-1">{cv.identity.email}</p>
          </div>
          <div>
            <p class="label">Web</p>
            <p class="mt-1">{cv.identity.website}</p>
          </div>
          <div>
            <p class="label">GitHub</p>
            <p class="mt-1">{cv.identity.github}</p>
          </div>
          <div>
            <p class="label">LinkedIn</p>
            <p class="mt-1">{cv.identity.linkedin}</p>
          </div>
        </div>
      </footer>
    </main>

    <PrintBar />
  </body>
</html>
