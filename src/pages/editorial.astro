---
export const prerender = true;

import "../styles/global.css";
import PrintBar from "../components/PrintBar.astro";
import { cv } from "../content";

const issueDate = new Date().toLocaleDateString("fr-FR", {
  month: "long",
  year: "numeric",
});
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{cv.identity.name} — Editorial</title>
    <style>
      body {
        font-family: var(--font-sans);
        background: #faf8f4;
        color: #1a1a1a;
      }
      .serif {
        font-family: var(--font-serif);
        font-optical-sizing: auto;
      }
      .rule {
        border-top: 1px solid #c9c2b5;
      }
      .drop-cap::first-letter {
        font-family: var(--font-serif);
        font-weight: 900;
        font-size: 5.5em;
        float: left;
        line-height: 0.85;
        padding-right: 0.08em;
        margin-top: 0.05em;
      }
      @media print {
        body {
          background: white;
        }
      }
    </style>
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-8 py-16 print:py-0">
      <!-- Masthead -->
      <header class="rule pt-6 pb-10 flex items-baseline justify-between text-xs uppercase tracking-[0.25em] text-neutral-600">
        <span>Issue N°01</span>
        <span class="serif italic text-base normal-case tracking-normal text-neutral-800">
          The {cv.identity.name} Quarterly
        </span>
        <span>{issueDate}</span>
      </header>

      <!-- Hero -->
      <section class="py-14 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-neutral-500">
          Curriculum Vitæ — Édition spéciale
        </p>
        <h1 class="serif mt-6 text-6xl sm:text-7xl font-light leading-[0.95] tracking-tight">
          {cv.identity.name}.
        </h1>
        <p class="serif mt-6 text-xl italic text-neutral-700">
          {cv.identity.title}.
        </p>
        <p class="mt-3 text-sm text-neutral-500">
          {cv.identity.location} · {cv.identity.availability}
        </p>
      </section>

      <!-- Lead paragraph -->
      <section class="rule pt-10 pb-12">
        <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-6">
          01 — À propos
        </p>
        <p class="serif text-lg leading-[1.7] text-neutral-800 drop-cap">
          {cv.about[0]}
        </p>
        {cv.about.slice(1).map((p) => (
          <p class="serif mt-4 text-lg leading-[1.7] text-neutral-800">{p}</p>
        ))}
      </section>

      <!-- Experience -->
      <section class="rule pt-10 pb-12">
        <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-8">
          02 — Expérience
        </p>
        <div class="space-y-12">
          {cv.experience.map((job) => (
            <article class="grid grid-cols-[1fr_2fr] gap-8">
              <div>
                <p class="serif italic text-neutral-500">{job.period}</p>
                <p class="text-xs uppercase tracking-widest mt-2 text-neutral-700">
                  {job.location}
                </p>
              </div>
              <div>
                <h3 class="serif text-2xl font-medium">{job.role}</h3>
                <p class="text-sm uppercase tracking-widest text-neutral-500 mt-1">
                  {job.company}
                </p>
                <p class="serif mt-3 leading-relaxed text-neutral-800">
                  {job.summary}
                </p>
                <ul class="serif mt-3 space-y-1 text-neutral-700 italic">
                  {job.highlights.map((h) => (
                    <li>— {h}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Selected work -->
      <section class="rule pt-10 pb-12">
        <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-8">
          03 — Selected work
        </p>
        <div class="grid sm:grid-cols-2 gap-8">
          {cv.projects.map((p) => (
            <div>
              <h3 class="serif text-xl font-medium">{p.name}</h3>
              <p class="serif italic mt-1 text-neutral-700">{p.tagline}</p>
              <p class="text-xs uppercase tracking-widest mt-3 text-neutral-500">
                {p.stack.join(" · ")}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- Skills + Education side by side -->
      <section class="rule pt-10 pb-12 grid sm:grid-cols-2 gap-12">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-6">
            04 — Compétences
          </p>
          <dl class="space-y-3 text-neutral-800">
            <div>
              <dt class="serif italic text-neutral-500">Langages</dt>
              <dd>{cv.skills.languages.join(", ")}</dd>
            </div>
            <div>
              <dt class="serif italic text-neutral-500">Infrastructure</dt>
              <dd>{cv.skills.infra.join(", ")}</dd>
            </div>
            <div>
              <dt class="serif italic text-neutral-500">Sécurité</dt>
              <dd>{cv.skills.security.join(", ")}</dd>
            </div>
          </dl>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-6">
            05 — Formation
          </p>
          <ul class="space-y-3">
            {cv.education.map((e) => (
              <li>
                <p class="serif text-lg">{e.title}</p>
                <p class="serif italic text-neutral-600">
                  {e.school} · {e.year}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Colophon -->
      <footer class="rule pt-8 pb-12 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-neutral-500 mb-3">
          Colophon
        </p>
        <p class="serif italic text-neutral-700">
          {cv.identity.email} · {cv.identity.website}
        </p>
        <p class="serif italic text-neutral-500 mt-1 text-sm">
          {cv.identity.github} · {cv.identity.linkedin}
        </p>
      </footer>
    </main>
    <PrintBar />
  </body>
</html>
