---
export const prerender = true;

import "../styles/global.css";
import PdfExportButton from "../components/PdfExportButton.astro";
import { getCV } from "../content";

const cv = getCV("vue");
const { identity, headline, about, experiences, projects, skills, education } = cv;
const pageTitle = `${identity.fullName} - ${headline.title}`;

const lastName = identity.fullName.replace(identity.firstName, "").trim();
const displayFirst = identity.firstName.split(" ")[0];
const monogram = (displayFirst[0] + lastName[0]).toUpperCase();

// Langues : standard pour le profil, à ajuster si besoin.
const languages = [
  { name: "Français", level: "Natif" },
  { name: "Anglais", level: "Technique" },
];

// Centres d'intérêt.
const hobbies = [
  { name: "Musiques", icon: "lucide:music" },
  { name: "Animés", icon: "lucide:tv" },
  { name: "Coder", icon: "lucide:code-xml" },
];

// Toutes les compétences à plat (grille de pastilles, comme la référence).
const allSkills = skills.flatMap((c) => c.items);

// Icône de marque par compétence (fallback : puce caramel).
const skillIcon: Record<string, string> = {
  "Vue 3": "logos:vue",
  "Nuxt 3": "logos:nuxt-icon",
  "Pinia": "logos:pinia",
  "Vue Router": "logos:vue",
  "TypeScript": "logos:typescript-icon",
  "JavaScript": "logos:javascript",
  "Tailwind CSS": "logos:tailwindcss-icon",
  "Figma": "logos:figma",
  "Vite": "logos:vitejs",
  "Git / GitHub / GitLab": "logos:git-icon",
  "Vercel": "logos:vercel-icon",
  "Firebase": "logos:firebase-icon",
  "WebSocket": "lucide:radio-tower",
  "Astro": "logos:astro-icon",
  "API REST": "lucide:webhook",
  "Axios": "lucide:arrow-left-right",
  "JWT auth": "logos:jwt-icon",
  "Supabase": "logos:supabase-icon",
};
---

<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={headline.tagline} />

    <!-- Iconify (lucide + logos icon sets) -->
    <script
      is:inline
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
    ></script>

    <style>
      @import url("https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@100,200,300,400,500,700,800,900&f[]=satoshi@300,400,500,700,900&display=swap");
      :root {
        --ink: #061321;
        --ink-soft: rgba(6, 19, 33, 0.6);
        --ink-border: rgba(6, 19, 33, 0.14);
        --paper: #ffffff;
        --shell: #ecebe7;
        --caramel: #aa7f56;
        --caramel-deep: #8e6843;
        --font-display: "Cabinet Grotesk", ui-sans-serif, system-ui, sans-serif;
        --font-body: "Satoshi", ui-sans-serif, system-ui, sans-serif;
      }

      body {
        font-family: var(--font-body);
        color: var(--ink);
      }
      body::selection,
      ::selection {
        background: var(--caramel);
        color: #fff;
      }

      .font-serif-d { font-family: var(--font-display); }
      .font-body { font-family: var(--font-body); }
      .text-ink { color: var(--ink); }
      .text-ink-soft { color: var(--ink-soft); }
      .text-caramel { color: var(--caramel); }
      .text-caramel-deep { color: var(--caramel-deep); }
      .bg-paper { background: var(--paper); }
      .bg-ink { background: var(--ink); }
      .bg-caramel { background: var(--caramel); }
      .border-ink-border { border-color: var(--ink-border); }
      .border-caramel-deep { border-color: var(--caramel-deep); }
      .divide-ink-border > * + * { border-color: var(--ink-border); }

      /* Titre de section */
      .sec-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--caramel-deep);
      }
      .sec-title iconify-icon { font-size: 16px; color: var(--caramel); }

      /* Pastille de contact / lien social */
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid var(--ink-border);
        border-radius: 8px;
        padding: 0.34rem 0.62rem;
        font-family: ui-monospace, "SFMono-Regular", monospace;
        font-size: 12.5px;
        line-height: 1.1;
        color: var(--ink-soft);
        transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
      }
      .pill:hover { border-color: var(--caramel-deep); color: var(--ink); }
      .pill iconify-icon { font-size: 15px; flex-shrink: 0; }

      /* Tag (stack, langue) */
      .tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid var(--ink-border);
        border-radius: 7px;
        padding: 0.28rem 0.58rem;
        font-family: ui-monospace, "SFMono-Regular", monospace;
        font-size: 11.5px;
        line-height: 1.1;
        color: var(--ink-soft);
        background: #fff;
        transition: border-color 0.15s ease, color 0.15s ease;
      }
      .tag:hover { border-color: var(--caramel-deep); color: var(--ink); }
      .tag iconify-icon { font-size: 18px; }

      /* Badge mono (période, année, LIVE) */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: ui-monospace, "SFMono-Regular", monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: 1px solid var(--ink-border);
        padding: 0.2rem 0.52rem;
        color: var(--ink-soft);
        white-space: nowrap;
      }
      .badge-live {
        border-color: var(--caramel-deep);
        color: var(--caramel-deep);
        font-weight: 700;
      }
      .badge-live::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--caramel);
      }

      /* Carte projet / ligne exp : léger hover */
      .row-hover { transition: background-color 0.18s ease; }
      .row-hover:hover { background: #faf8f5; }
      .row-hover:hover .row-title { color: var(--caramel-deep); }
      .row-title { transition: color 0.18s ease; }

      /* ─── Mode export PDF (ConvertAPI, ?export=pdf) ───
         On retire l'habillage "écran" (fond gris, marges, coin arrondi,
         ombre, largeur max) pour que la feuille remplisse la page :
         le bas non utilisé devient une marge blanche normale, plus le
         vide gris disgracieux à l'impression. */
      html.pdf-export-mode body { background: #fff; }
      html.pdf-export-mode .cv-shell { padding: 0; min-height: 0; display: block; }
      html.pdf-export-mode .cv-sheet {
        max-width: none;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }
    </style>
  </head>

  <body>
    <div class="cv-shell min-h-screen w-full flex justify-center p-6">
      <main
        class="cv-sheet w-full max-w-[880px] bg-paper border border-ink-border overflow-hidden"
      >
        <!-- ════════ HEADER BAND ════════ -->
        <header class="flex items-stretch gap-5 p-6 border-b border-ink-border">
          <div
            class="w-24 h-24 md:w-28 md:h-28 shrink-0 rounded-xl bg-ink text-paper flex items-center justify-center relative overflow-hidden"
          >
            <span class="font-serif-d text-5xl font-bold tracking-tight">{monogram}</span>
            <span class="absolute bottom-1.5 right-2 font-mono text-[8px] tracking-[0.3em] text-caramel uppercase">dev</span>
            <img
              src="/profile.jpg"
              alt={identity.fullName}
              class="absolute inset-0 w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
          </div>

          <!-- Name + title + social -->
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h1 class="font-serif-d text-3xl md:text-4xl leading-[0.95] tracking-tight">
              <span class="font-bold text-ink">{displayFirst}</span>
              <span class="text-ink-soft font-medium">{lastName}</span>
            </h1>
            <p class="mt-2 font-mono text-[15px] md:text-[16px] font-bold uppercase tracking-[0.18em] text-caramel-deep">
              {headline.title}
            </p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              <a class="pill" href={identity.githubUrl} target="_blank" rel="noopener">
                <iconify-icon icon="lucide:github"></iconify-icon>{identity.github}
              </a>
              <a class="pill" href={identity.linkedinUrl} target="_blank" rel="noopener">
                <iconify-icon icon="lucide:linkedin"></iconify-icon>linkedin.com/in/marc-aurel
              </a>
              <a class="pill" href={identity.wakatimeUrl} target="_blank" rel="noopener">
                <iconify-icon icon="lucide:clock"></iconify-icon>{identity.wakatime}
              </a>
            </div>
          </div>

          <!-- Logo monogram -->
          <div
            class="shrink-0 self-start w-11 h-11 rounded-full border border-ink-border flex items-center justify-center"
          >
            <span class="font-serif-d text-sm font-bold text-ink">{monogram}</span>
          </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-12">
          <aside
            class="md:col-span-4 p-5 flex flex-col gap-7 border-b md:border-b-0 md:border-r border-ink-border"
          >
            <!-- Profil -->
            <section>
              <h3 class="sec-title">
                <iconify-icon icon="lucide:user"></iconify-icon>Profil
              </h3>
              <p class="mt-3 text-[14px] leading-relaxed text-ink-soft text-justify">
                {about.slice(0, 2).join(" ")}
              </p>
            </section>

            <!-- Contact -->
            <section>
              <h3 class="sec-title">
                <iconify-icon icon="lucide:contact"></iconify-icon>Contact
              </h3>
              <div class="mt-3 flex flex-col gap-2">
                <a class="pill justify-start!" href={`tel:${identity.phone.replace(/\s/g, "")}`}>
                  <iconify-icon icon="lucide:phone" class="text-caramel"></iconify-icon>{identity.phone}
                </a>
                <a class="pill justify-start!" href={`mailto:${identity.email}`}>
                  <iconify-icon icon="lucide:mail" class="text-caramel"></iconify-icon>
                  <span class="truncate">{identity.email}</span>
                </a>
                <span class="pill justify-start!">
                  <iconify-icon icon="lucide:map-pin" class="text-caramel"></iconify-icon>{identity.location}
                </span>
              </div>
            </section>

            <!-- Formation -->
            <section>
              <h3 class="sec-title">
                <iconify-icon icon="lucide:graduation-cap"></iconify-icon>Formation
              </h3>
              <div class="mt-3 flex flex-col gap-4">
                {education.map((e) => (
                  <div>
                    <span class="badge mb-1">{e.period}</span>
                    <h4 class="mt-1.5 font-serif-d text-[16px] leading-tight text-ink">{e.title}</h4>
                    <p class="text-[13px] text-caramel-deep mt-0.5">{e.field}</p>
                    <p class="text-[12.5px] text-ink-soft leading-snug">{e.school}</p>
                  </div>
                ))}
              </div>
            </section>

            <!-- Langues -->
            <section>
              <h3 class="sec-title">
                <iconify-icon icon="lucide:languages"></iconify-icon>Langues
              </h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {languages.map((l) => (
                  <span class="tag">
                    <span class="font-semibold text-ink">{l.name}</span>
                    <span class="text-caramel-deep">{l.level}</span>
                  </span>
                ))}
              </div>
            </section>

            <!-- Hobbies -->
            <section>
              <h3 class="sec-title">
                <iconify-icon icon="lucide:heart"></iconify-icon>Hobbies
              </h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {hobbies.map((h) => (
                  <span class="tag">
                    <iconify-icon icon={h.icon} class="text-caramel"></iconify-icon>
                    <span class="font-semibold text-ink">{h.name}</span>
                  </span>
                ))}
              </div>
            </section>
          </aside>

          <!-- ─── MAIN ─── -->
          <div class="md:col-span-8 flex flex-col">
            <!-- Projets -->
            <section data-pdf-break="projects" class="border-b border-ink-border">
              <h3 class="sec-title p-4">
                <iconify-icon icon="lucide:folder-code"></iconify-icon>Projets
              </h3>
              <div class="mt-4 flex flex-col">
                {projects.map((p) => (
                  <article class="row-hover p-4 first:pt-0 border-b border-ink-border last:border-b-0">
                    <div class="flex items-start justify-between gap-3">
                      <h4 class="row-title font-serif-d text-lg leading-tight text-ink">{p.name}</h4>
                      <div class="flex items-center gap-1.5 shrink-0">
                        {p.live && (
                          <a class="badge badge-live" href={`https://${p.live}`} target="_blank" rel="noopener">Live</a>
                        )}
                        {p.link && (
                          <a class="badge" href={`https://${p.link}`} target="_blank" rel="noopener">
                            <iconify-icon icon="lucide:github"></iconify-icon>Code
                          </a>
                        )}
                      </div>
                    </div>
                    <p class="mt-0.5 font-mono text-[12px] text-caramel-deep uppercase tracking-wide">{p.tagline}</p>
                    <p class="mt-1.5 text-[13.5px] leading-relaxed text-ink-soft">{p.description}</p>
                    <div class="mt-2 flex flex-wrap gap-1.5">
                      {p.stack.map((s) => (
                        <span class="tag !text-[11.5px]">{s}</span>
                      ))}
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <!-- Expérience -->
            <section data-pdf-break="experience" class="border-b border-ink-border">
              <h3 class="sec-title p-4">
                <iconify-icon icon="lucide:briefcase"></iconify-icon>Expérience
              </h3>
              <div class="mt-4 flex flex-col">
                {experiences.map((j) => (
                  <div class="row-hover p-4 first:pt-0 border-b border-ink-border last:border-b-0">
                    <div class="flex items-baseline justify-between gap-3">
                      <span class="font-mono text-[14px] font-semibold text-ink leading-tight">{j.company}</span>
                      <span class="badge shrink-0">{j.period}</span>
                    </div>
                    <h4 class="row-title font-serif-d text-[16px] leading-tight text-ink mt-1.5">{j.role}</h4>
                    <p class="mt-1 text-[13.5px] leading-relaxed text-ink-soft">{j.summary.vue}</p>
                  </div>
                ))}
              </div>
            </section>

            <!-- Compétences -->
            <section class="p-4">
              <h3 class="sec-title">
                <iconify-icon icon="lucide:cpu"></iconify-icon>Compétences
              </h3>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {allSkills.map((s) => (
                  <span class="tag">
                    <iconify-icon icon={skillIcon[s] ?? "lucide:dot"} class={skillIcon[s] ? "" : "text-caramel"}></iconify-icon>
                    {s}
                  </span>
                ))}
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>

    <PdfExportButton
      path="/light-neo-brutalist"
      filename="Marc-Aurel-AHOUANDJINOU-CV-Vue.pdf"
      accent="#aa7f56"
      accentDeep="#8e6843"
    />
  </body>
</html>